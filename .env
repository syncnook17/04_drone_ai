# ==========================================
# Server Network Settings
# ==========================================
# ใส่ IP ของ Ubuntu Server ของคุณ (เช่น 192.168.1.50 หรือ Public IP)
SERVER_IP=192.168.1.120
# พอร์ตที่ RC เปิด browser (nginx gateway)
DJANGO_PORT=8007
# Django runserver รันที่พอร์ตนี้ (nginx proxy มา)
DJANGO_INTERNAL_PORT=8008

# MQTT WebSocket ผ่าน gateway พอร์ต 8007 (/mqtt) — RC เปิด 8007 ได้แต่ 8083 อาจถูกบล็อก
MQTT_WS_USE_GATEWAY=true
MQTT_WS_GATEWAY_PATH=/mqtt

# พอร์ต MQTT ที่ Pilot/RC จะเชื่อม (มาตรฐาน DJI ใช้ 1883)
MQTT_PUBLIC_PORT=8006

# ==========================================
# DJI Workspace — ข้อมูล "พื้นที่ทำงาน" บน Pilot 2 (ไม่ใช่ EMQX!)
# ==========================================
# ค่าเหล่านี้เป็นชื่อที่แสดงบน DJI Pilot 2 หลังเชื่อมต่อสำเร็จ
# ไม่ได้มาจาก EMQX Dashboard และไม่ต้องไปตั้งใน DJI Portal
#
# DJI_WORKSPACE_ID = UUID ของ workspace ในระบบคุณ (รูปแบบ xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
#   → สร้างเองได้ที่ https://www.uuidgenerator.net/ หรือใช้ค่าด้านล่างได้เลย
# DJI_PLATFORM_NAME = ชื่อแพลatform แสดงบนแถบด้านบนของ WebView ใน Pilot
# DJI_WORKSPACE_NAME = ชื่อ workspace แสดงที่เมนู Cloud ใน Pilot
# DJI_WORKSPACE_DESC = คำอธิบายสั้นๆ แสดงใน Pilot
DJI_WORKSPACE_ID=e3dea0f5-37f2-4d79-ae58-490af3228069
DJI_PLATFORM_NAME=DDM Drone AI
DJI_WORKSPACE_NAME=Matrice 4E Field Ops
DJI_WORKSPACE_DESC=Ubuntu Server Telemetry & AI

# ==========================================
# MQTT Broker Settings (ตรงกับใน docker-compose)
# ==========================================
MQTT_PORT=1883
# DJI Demo มาตรฐาน — login + MQTT ใช้คู่นี้ (ไม่ใช่ admin!)
PILOT_USERNAME=pilot
PILOT_PASSWORD=pilot123
MQTT_USER=pilot
MQTT_PASSWORD=pilot123
# Telemetry listener ใช้ admin subscribe topic DJI (EMQX บล็อก #)
MQTT_LISTENER_USER=admin
MQTT_LISTENER_PASSWORD=admin1234
# ใช้ false ตามมาตรฐาน DJI Demo (Pilot ต้องได้ mqtt_username/password จริง)
MQTT_USE_ANONYMOUS=false
MQTT_WS_PORT=8083

# ==========================================
# RTMP / Livestream Settings (SRS)
# ==========================================
RTMP_PORT=1935
SRS_HTTP_PORT=8085
RTMP_APP=live
RTMP_STREAM_KEY=drone