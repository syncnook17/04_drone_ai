# ==========================================
# DJI Developer Credentials (ได้จาก dji developer portal)
# ==========================================
DJI_APP_ID=your_dji_app_id_here
DJI_APP_KEY=your_dji_app_key_here
DJI_APP_LICENSE=your_dji_app_license_here

# ==========================================
# Server Network Settings
# ==========================================
# ใส่ IP ของ Ubuntu Server ของคุณ (เช่น 192.168.1.50 หรือ Public IP)
SERVER_IP=192.168.1.XXX 

# ==========================================
# MQTT Broker Settings (ตรงกับใน docker-compose)
# ==========================================
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASSWORD=admin1234